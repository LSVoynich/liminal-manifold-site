# Custom 404 page
ErrorDocument 404 /404.html

# Redirect www to non-www (canonical domain)
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.liminalmanifold\.com [NC]
RewriteRule ^(.*)$ https://liminalmanifold.com/$1 [R=301,L]

# Redirect old Almost Supernova URLs to Quantum Eve
RewriteRule ^artists/almost-supernova(/.*)?$ /artists/quantum-eve$1 [R=301,L]
